class Solution {
public:
    int climbStairs(int n) {
        // Base cases
        if (n <= 2) {
            return n;
        }

        int prev2 = 1; // Ways to reach step 1
        int prev1 = 2; // Ways to reach step 2
        int current = 0;

        for (int i = 3; i <= n; ++i) {
            current = prev1 + prev2; // Sum of the last two steps
            prev2 = prev1;           // Move pointer 2 steps back forward
            prev1 = current;         // Move pointer 1 step back forward
        }

        return current;
    }
};
